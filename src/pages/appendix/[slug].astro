---
import PaperLayout from '../../layouts/PaperLayout.astro';
import '../../styles/paper.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const papers = await getCollection('appendix');
  return papers.map((paper) => ({
    params: { slug: paper.id.replace(/\.md$/, '') },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);
---

<PaperLayout
  title={paper.data.title}
  subtitle={paper.data.subtitle}
  description={`${paper.data.title} — REDI White Paper Series`}
  prevLink={{ href: '/appendix', label: 'Research Repository' }}
>
  <div class="paper-meta">
    <span class="meta-category">{paper.data.category.replace(/-/g, ' ')}</span>
    <span class="meta-date">{paper.data.date}</span>
    <button class="pdf-btn pdf-btn-inline" onclick="window.print()">
      Save as PDF
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <Content />
</PaperLayout>

<style>
  .paper-meta {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .meta-category {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-red);
    font-weight: 700;
  }

  .meta-date {
    font-size: var(--text-xs);
    color: var(--color-gray-300);
  }
</style>
