---
import rediLogo from '../assets/images/redi-logo.svg';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Conquering Cancer — REDI White Paper Series' } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
const isAppendix = currentPath.startsWith('/appendix');
const isTeam = currentPath.startsWith('/team');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Conquering Cancer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="print-header">
      <img src={rediLogo.src} alt="REDI" width="100" height="48" />
    </div>
    <slot name="header">
      <header class="site-header">
        <nav class="container-wide site-nav">
          <a href="/" class="nav-logo">
            <img src={rediLogo.src} alt="REDI" width="80" height="38" />
          </a>
          <ul class="nav-links">
            <li><a href="/" class:list={[{ 'nav-active': isHome }]}>Conquering Cancer</a></li>
            <li><a href="/appendix" class:list={[{ 'nav-active': isAppendix }]}>Research Repository</a></li>
            <li><a href="/team" class:list={[{ 'nav-active': isTeam }]}>REDI Team</a></li>
          </ul>
          <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </nav>
      </header>
    </slot>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-content">
          <p class="footer-brand">Ratner Early Detection Initiative</p>
          <p class="footer-copy">&copy; {new Date().getFullYear()} REDI. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/print.css';
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .nav-logo img {
    height: 38px;
    width: auto;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: var(--space-8);
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-gray-700);
    font-weight: 400;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--color-black);
  }

  .nav-active {
    font-weight: 700 !important;
    color: var(--color-red) !important;
  }

  .nav-active:hover {
    color: var(--color-red-dark) !important;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    flex-direction: column;
    gap: 5px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-black);
    transition: all 0.2s ease;
  }

  .site-footer {
    margin-top: var(--space-32);
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-gray-200);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-black);
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--color-gray-500);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--color-white);
      border-bottom: 1px solid var(--color-gray-200);
      flex-direction: column;
      padding: var(--space-6);
      gap: var(--space-4);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }

    .footer-content {
      flex-direction: column;
      gap: var(--space-2);
      text-align: center;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links.classList.toggle('open');
    });
  }
</script>
